        {
          "name": "Create Menu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "",
                  "/* 1. Status code */",
                  "pm.test('Status code is 201', function () {",
                  "  pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "/* 2. success */",
                  "pm.test('success is boolean and equals true', function () {",
                  "  pm.expect(jsonData.success).to.be.a('boolean');",
                  "  pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "",
                  "/* ===== guard เฉพาะตอนผ่านจริง ===== */",
                  "if (pm.response.code === 201 && jsonData.success === true) {",
                  "",
                  "  pm.test('data is an object', function () {",
                  "    pm.expect(jsonData.data).to.be.an('object');",
                  "  });",
                  "",
                  "  pm.test('data has _id', function () {",
                  "    pm.expect(jsonData.data).to.have.property('_id').that.is.a('string');",
                  "  });",
                  "",
                  "  pm.test('data has restaurant', function () {",
                  "    pm.expect(jsonData.data).to.have.property('restaurant').that.is.a('string');",
                  "  });",
                  "",
                  "  pm.test('data has items array', function () {",
                  "    pm.expect(jsonData.data).to.have.property('items').that.is.an('array');",
                  "  });",
                  "",
                  "  /* set variables */",
                  "  pm.collectionVariables.set('menuId', jsonData.data._id);",
                  "  pm.collectionVariables.set('menuRestaurantId', jsonData.data.restaurant);",
                  "}"
                ],

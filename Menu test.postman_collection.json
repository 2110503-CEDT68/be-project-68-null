        {
          "name": "Get All Menu",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"success is boolean and equals true\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.a(\"boolean\");",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test(\"count is a number\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.count).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"data is an array\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"count equals data.length\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.count).to.eql(jsonData.data.length);",
                  "});",
                  "",
                  "pm.test(\"each item in data has _id, restaurant, and items fields\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        jsonData.data.forEach(function (item) {",
                  "            pm.expect(item._id).to.be.a(\"string\");",
                  "            pm.expect(item.restaurant).to.be.a(\"string\");",
                  "            pm.expect(item.items).to.be.an(\"array\");",
                  "        });",
                  "    }",
                  "});",
                  ""
                ]
              }
            }
          ],

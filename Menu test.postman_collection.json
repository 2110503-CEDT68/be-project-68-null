        {
          "name": "Log in Copy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set(\"TOKEN\",pm.response.json().token)",
                  "",
                  "pm.test('Response time < 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "})",
                  "",
                  "pm.test('Login: status is 200/201 or expected error', function () {",
                  "    pm.expect([",
                  "        200,",
                  "        201,",
                  "        400,",
                  "        401",
                  "    ]).to.include(pm.response.code);",
                  "})",
                  "",
                  "pm.test('Login: JSON body has {success}', function () {",
                  "    pm.response.to.be.withBody;",
                  "    pm.response.to.be.json;",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success');",
                  "    pm.expect(jsonData.success).to.be.a('boolean');",
                  "})",
                  "",
                  "pm.test('Login: capture token if present', function () {",
                  "    if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "        var jsonData = pm.response.json();",
                  "        var token = jsonData && jsonData.token || jsonData && jsonData.data && jsonData.data.token;",
                  "        pm.expect(token, 'token present in login response').to.exist;",
                  "        if (token) {",
                  "            pm.environment.set('TOKEN', token);",
                  "        }",
                  "    }",
                  "})",
                  "",
                  "pm.test('Login: error schema on non-2xx', function () {",
                  "    if (pm.response.code < 200 || pm.response.code >= 300) {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('success', false);",
                  "        pm.expect(jsonData).to.satisfy(function (b) {",
                  "            return b.error || b.message || b.errors;",
                  "        });",
                  "    }",
                  "})"
                ]
              }
            }
          ],

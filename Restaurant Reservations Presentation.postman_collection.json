  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Set DYNAMIC_DATE once per iteration (when 'User Register' request runs)",
          "// Each iteration gets a unique weekday far in the future",
          "if (pm.info.requestName === 'User Register') {",
          "    let iter = parseInt(pm.collectionVariables.get('ITER_COUNT') || '0');",
          "    iter++;",
          "    pm.collectionVariables.set('ITER_COUNT', iter);",
          "",
          "    // Base: Monday 2027-06-07 (far future, no existing reservations)",
          "    const baseDate = new Date('2027-06-07');",
          "    let offset = iter - 1;",
          "    // Map offset to weekdays only: skip Sat/Sun",
          "    let totalDays = Math.floor(offset / 5) * 7 + (offset % 5);",
          "    const target = new Date(baseDate.getTime() + totalDays * 86400000);",
          "",
          "    const y = target.getFullYear();",
          "    const m = String(target.getMonth() + 1).padStart(2, '0');",
          "    const d = String(target.getDate()).padStart(2, '0');",
          "    pm.collectionVariables.set('DYNAMIC_DATE', `${y}-${m}-${d}T11:00:00.000+07:00`);",
          "}"
        ]
      }
    },

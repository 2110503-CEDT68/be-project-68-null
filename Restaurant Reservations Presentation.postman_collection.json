  "item": [
    {
      "name": "User Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.set(\"TOKEN\", pm.response.json().token);",
              "",
              "const registerResponse = pm.response.json();",
              "if (registerResponse && registerResponse.data && registerResponse.data._id) {",
              "    pm.environment.set(\"UserId\", registerResponse.data._id);",
              "}",
              "",
              "const requestBody = JSON.parse(pm.request.body.raw);",
              "pm.environment.set(\"UserEmail\", requestBody.email);",
              "pm.environment.set(\"UserPassword\",requestBody.password);",
              "",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.execution.setNextRequest(\"User Register - Name is NULL\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }

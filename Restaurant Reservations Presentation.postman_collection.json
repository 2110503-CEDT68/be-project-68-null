    {
      "name": "User Get Own Reservations (Cleanup Check)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// GET own reservations to check how many extra reservations exist\r",
              "// Then capture ExtraReservationId2 and ExtraReservationId3 for cleanup\r",
              "// Set flags HasExtra2 and HasExtra3 to control conditional flow\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const reservations = pm.response.json();\r",
              "let hasExtra2 = false;\r",
              "let hasExtra3 = false;\r",
              "\r",
              "if (reservations && Array.isArray(reservations.data) && reservations.data.length > 1) {\r",
              "    pm.environment.set(\"ExtraReservationId2\", reservations.data[1]._id);\r",
              "    hasExtra2 = true;\r",
              "}\r",
              "if (reservations && Array.isArray(reservations.data) && reservations.data.length > 2) {\r",
              "    pm.environment.set(\"ExtraReservationId3\", reservations.data[2]._id);\r",
              "    hasExtra3 = true;\r",
              "}\r",
              "\r",
              "pm.environment.set(\"HasExtra2\", hasExtra2);\r",
              "pm.environment.set(\"HasExtra3\", hasExtra3);\r",
              "\r",
              "if (hasExtra2) {\r",
              "    pm.execution.setNextRequest(\"User Delete Extra Reservation #2\");\r",
              "} else {\r",
              "    pm.execution.setNextRequest(\"User View own Reservations\");\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],

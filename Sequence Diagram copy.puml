@startuml Restaurant Reservation System

skinparam style strictuml
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 0
skinparam sequenceParticipantPadding 20

skinparam actor {
  BorderColor black
  BackgroundColor #e8d5b0
  FontColor black
}
skinparam participant {
  BorderColor black
  BackgroundColor #aed6f1
  FontColor black
}
skinparam sequence {
  ArrowColor black
  LifeLineBorderColor black
  LifeLineBackgroundColor #d6eaf8
  DividerBackgroundColor #fef9e7
  DividerBorderColor #b7950b
  DividerFontColor #7d6608
  DividerFontSize 13
}
skinparam note {
  BorderColor #b7950b
  BackgroundColor #fef9e7
}

actor "User" as U
participant "interface : UI" as UI #fdebd0
participant "mainController :\nController" as MC #aed6f1
participant "router : Router" as R #d5f5e3
participant "MongoDB" as DB #d2b4de

' ==========================================
== 1. Register ==
' ==========================================

U -> UI : fill register form\n(name, tel, email, password)
U -> UI : click [Register]
UI -> MC : register(name, tel, email, password)
MC -> R : POST /api/v1/auth/register
R -> DB : User.create(...)
DB --> R : user object
R -> R : getSignedJwtToken()
R --> MC : 201 { success, token }
MC --> UI : show success
UI --> U : redirect to restaurants page

' ==========================================
== 2. Login ==
' ==========================================

U -> UI : fill login form\n(email, password)
U -> UI : click [Login]
UI -> MC : login(email, password)
MC -> R : POST /api/v1/auth/login
R -> DB : User.findOne({ email })
DB --> R : user object

alt Invalid credentials
  R --> MC : 401 Invalid credentials
  MC --> UI : show error message
  UI --> U : display error
else Valid credentials
  R -> R : matchPassword()\ngetSignedJwtToken()
  R --> MC : 200 { success, token }
  MC --> UI : store token
  UI --> U : redirect to restaurants page
end

' ==========================================
== 3. Get All Restaurants ==
' ==========================================

U -> UI : click [ร้านอาหาร]
UI -> MC : getRestaurants()
MC -> R : GET /api/v1/restaurants
R -> DB : Restaurant.find()\n.sort().skip().limit()
DB --> R : restaurants[]
R --> MC : 200 { success, count, pagination, data }
MC --> UI : display restaurant cards
UI --> U : show restaurant list

' ==========================================
== 4. Create Reservation ==
' ==========================================

U -> UI : click [จองโต๊ะ]
U -> UI : fill form (reservationDate, tableCount)
U -> UI : click [ยืนยันการจอง]
UI -> MC : addReservation(restaurantId, date, tableCount)
MC -> R : POST /api/v1/restaurants/:restaurantId/reservations\n+ Bearer Token

R -> R : protect() — verify JWT

alt Token invalid
  R --> MC : 401 Unauthorized
  MC --> UI : show error
  UI --> U : display error
else Token valid
  R -> DB : Restaurant.findById(restaurantId)
  DB --> R : restaurant
  R -> DB : check reservations on same date
  DB --> R : sameDateReservations[]

  alt Already 3 reservations on this date
    R --> MC : 400 Already 3 reservations
    MC --> UI : show error
    UI --> U : display error
  else Under limit
    R -> R : checkOpeningHours()
    alt Restaurant closed
      R --> MC : 400 Closed on <day>
      MC --> UI : show error
      UI --> U : display error
    else Open
      R -> DB : check table availability (overlap ±2hr)
      DB --> R : availability result
      alt Not enough tables
        R --> MC : 400 Not enough tables
        MC --> UI : show error
        UI --> U : display error
      else Tables available
        R -> R : endTime = reservationDate + 2hr
        R -> DB : Reservation.create(...)
        DB --> R : reservation object
        R --> MC : 201 { success, data }
        MC --> UI : show success
        UI --> U : reservation confirmed
      end
    end
  end
end

' ==========================================
== 5. Update Reservation ==
' ==========================================

U -> UI : click [แก้ไขการจอง]
U -> UI : change reservationDate / tableCount
U -> UI : click [บันทึก]
UI -> MC : updateReservation(id, body)
MC -> R : PUT /api/v1/reservations/:id\n+ Bearer Token

R -> R : protect() — verify JWT
R -> DB : Reservation.findById(id)
DB --> R : reservation

alt Reservation not found
  R --> MC : 404 Not found
  MC --> UI : show error
else Found
  R -> R : check ownership
  alt Not authorized
    R --> MC : 403 Forbidden
    MC --> UI : show error
    UI --> U : display error
  else Authorized
    R -> R : re-validate opening hours & availability
    alt Validation failed
      R --> MC : 400 Closed or not enough tables
      MC --> UI : show error
      UI --> U : display error
    else Passed
      R -> DB : Reservation.findByIdAndUpdate(...)
      DB --> R : updated reservation
      R --> MC : 200 { success, data }
      MC --> UI : show success
      UI --> U : reservation updated
    end
  end
end

' ==========================================
== 6. Delete Reservation ==
' ==========================================

U -> UI : click [ยกเลิกการจอง]
U -> UI : confirm dialog
UI -> MC : deleteReservation(id)
MC -> R : DELETE /api/v1/reservations/:id\n+ Bearer Token

R -> R : protect() — verify JWT
R -> DB : Reservation.findById(id)
DB --> R : reservation

alt Reservation not found
  R --> MC : 404 Not found
  MC --> UI : show error
else Found
  R -> R : check ownership
  alt Not authorized
    R --> MC : 403 Forbidden
    MC --> UI : show error
    UI --> U : display error
  else Authorized
    R -> DB : reservation.deleteOne()
    DB --> R : ok
    R --> MC : 200 { success, data: {} }
    MC --> UI : remove from list
    UI --> U : reservation cancelled
  end
end

@enduml
